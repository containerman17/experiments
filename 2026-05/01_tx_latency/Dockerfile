FROM golang:1.24-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/txlat ./...

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/txlat /txlat
EXPOSE 9090
USER nonroot:nonroot
ENTRYPOINT ["/txlat"]
